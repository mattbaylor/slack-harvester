# User config (contains paths specific to each person)
config.json

# Chrome profile
.slack-harvest-profile/

# State files (local to each vault)
_state/
_pending/
seen.json
*-cache.json
token.json
# Pushed creds persistence (0600, in state_dir) — never commit (ISSUES #17)
creds.json

# Real Slack windows fetched from the API may contain personal DM content —
# keep those out of git. Synthetic/hand-built fixtures (e.g.
# tests/fixtures/rangel-window.json) ARE committed: they're test data with no
# real message content, and the suite must be green on a fresh clone.
tests/fixtures/*.real.json

# Python
__pycache__/
*.pyc
.venv/
*.egg-info/

# OS
.DS_Store

# Playwright MCP session artifacts (local browser-automation logs/snapshots)
.playwright-mcp/
